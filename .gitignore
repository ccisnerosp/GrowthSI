# dependencies (cualquier nivel del monorepo)
node_modules/
.pnp
.pnp.*

# Python (apps/ai-service)
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
*.egg-info/

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (cualquier nivel) — pero permitir los .env.example
.env
**/.env
.env.*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# RAG knowledge base (PDFs bajo licencia, no commitear)
knowledge/*.pdf
knowledge/*/

