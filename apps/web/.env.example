# ────────────────────────────────────────────────────────────────
# GrowthSI — SERVICIO WEB (Next.js) · variables de entorno
# Copia como `.env`. NUNCA commitees `.env`.
# El AI service tiene su propio archivo: apps/ai-service/.env
# ────────────────────────────────────────────────────────────────

# ─── Base de datos (Postgres + pgvector) ────────────────────────
# Local directo:   postgresql://postgres:postgres@localhost:5432/growthsi
# docker-compose:  postgresql://postgres:postgres@postgres:5432/growthsi
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/growthsi?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/growthsi?schema=public"

# ─── Auth.js (next-auth v5) ─────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ─── AI Service (proxy hacia FastAPI :8000) ─────────────────────
# Next.js es el ÚNICO que llama al AI service. El navegador nunca.
#   Local directo:  http://localhost:8000
#   docker-compose: http://ai-service:8000
#   Producción:     https://<ai-service-internal> (ingress internal)
AI_SERVICE_URL="http://localhost:8000"
# Debe coincidir con AI_SERVICE_API_KEY de apps/ai-service/.env
AI_SERVICE_API_KEY="dev-shared-secret-change-me"

# ─── Entra ID (login empresarial multi-tenant · Fase 1) ────────────────
# Si NO se setean, el provider Entra queda desactivado y el login sigue por
# credenciales (no rompe nada). App registration multi-tenant (AzureADMultipleOrgs);
# redirect URIs a registrar: <AUTH_URL>/api/auth/callback/microsoft-entra-id
# y <AUTH_URL>/api/onboarding/consent-callback
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""

# NOTA: OPENAI_API_KEY / OPENAI_* ya NO van en el servicio web — el LLM lo
# maneja el AI service. Tras completar la migración, esas vars viven solo en
# apps/ai-service/.env.
