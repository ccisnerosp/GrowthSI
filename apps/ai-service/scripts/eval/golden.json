{
  "_descripcion": "Gold set para evaluar la RECUPERACIÓN del RAG. Cada entrada: una consulta y los anclajes que un chunk relevante debería contener (número de cláusula + término clave). 'fuentes' filtra el corpus. Cúralo/extiéndelo con el tiempo: a más entradas, métricas más fiables.",
  "casos": [
    { "id": "iso-4.3-alcance",        "query": "¿Cómo se determina el alcance del SGSI?",                         "fuentes": ["iso27001_2022"], "expect_any": ["4.3", "alcance"] },
    { "id": "iso-4.2-partes",         "query": "Necesidades y expectativas de las partes interesadas",            "fuentes": ["iso27001_2022"], "expect_any": ["4.2", "partes interesadas"] },
    { "id": "iso-5.2-politica",       "query": "Política de seguridad de la información",                          "fuentes": ["iso27001_2022"], "expect_any": ["5.2", "política"] },
    { "id": "iso-6.1.2-eval-riesgo",  "query": "Cómo realizar la evaluación de riesgos de seguridad",             "fuentes": ["iso27001_2022"], "expect_any": ["6.1.2", "evaluación de riesgos"] },
    { "id": "iso-6.1.3-soa",          "query": "Tratamiento de riesgos y declaración de aplicabilidad",           "fuentes": ["iso27001_2022"], "expect_any": ["6.1.3", "aplicabilidad"] },
    { "id": "iso-6.2-objetivos",      "query": "Objetivos de seguridad de la información y su planificación",      "fuentes": ["iso27001_2022"], "expect_any": ["6.2", "objetivos"] },
    { "id": "iso-9.2-auditoria",      "query": "Auditoría interna del sistema de gestión",                        "fuentes": ["iso27001_2022"], "expect_any": ["9.2", "auditoría"] },
    { "id": "iso-10.2-noconf",        "query": "No conformidad y acción correctiva",                              "fuentes": ["iso27001_2022"], "expect_any": ["10.2", "no conformidad"] },
    { "id": "ctrl-8.8-vuln",          "query": "Gestión de vulnerabilidades técnicas",                            "fuentes": ["base_iso_27002_controles"], "expect_any": ["8.8", "vulnerabilidad"] },
    { "id": "ctrl-8.24-cripto",       "query": "Uso de criptografía y gestión de claves",                         "fuentes": ["base_iso_27002_controles"], "expect_any": ["8.24", "criptografía"] },
    { "id": "ctrl-8.13-backup",       "query": "Copias de respaldo de la información",                             "fuentes": ["base_iso_27002_controles"], "expect_any": ["8.13", "respaldo"] },
    { "id": "ctrl-5.15-acceso",       "query": "Control de acceso a la información",                               "fuentes": ["base_iso_27002_controles"], "expect_any": ["5.15", "control de acceso"] },
    { "id": "ctrl-6.3-concienciacion","query": "Concienciación, educación y formación en seguridad",              "fuentes": ["base_iso_27002_controles"], "expect_any": ["6.3", "concienciación"] },
    { "id": "ctrl-8.15-logging",      "query": "Registro de eventos y monitoreo (logging)",                       "fuentes": ["base_iso_27002_controles"], "expect_any": ["8.15", "registro"] },

    { "id": "thr-tec-exfil",          "query": "Exfiltración de datos hacia un servicio web o la nube",            "fuentes": ["base_mitre_attack_enterprise"], "expect_any": ["exfiltration"] },
    { "id": "thr-tec-exec",           "query": "Malware que ejecuta comandos en servidores",                       "fuentes": ["base_mitre_attack_enterprise"], "expect_any": ["command", "execution", "scripting"] },
    { "id": "thr-per-socialeng",      "query": "Ingeniería social y acceso inicial al personal",                   "fuentes": ["base_mitre_attack_social_eng"], "expect_any": ["phishing", "spearphishing", "social", "compromise"] },
    { "id": "thr-fis-robo",           "query": "Robo o pérdida de equipos con información sensible",               "fuentes": ["base_enisa_amenazas_fisicas"], "expect_any": ["robo", "dispositivos", "pérdida"] },
    { "id": "thr-fis-acceso",         "query": "Acceso físico no autorizado a instalaciones",                     "fuentes": ["base_enisa_amenazas_fisicas"], "expect_any": ["acceso físico", "no autorizado", "instalaciones"] },
    { "id": "thr-org-amenazas",       "query": "Tendencias de amenazas y ataques recientes al negocio",           "fuentes": ["base_enisa_threat_landscape", "base_iso_27005_amenazas"], "expect_any": ["threat", "amenaza", "ransomware", "ttp"] }
  ]
}
